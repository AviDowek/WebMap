# Required: Anthropic API key for Claude LLM analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional: API server authentication key (if unset, API is open to all)
WEBMAP_API_KEY=

# Optional: Comma-separated list of allowed CORS origins (defaults to http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# Optional: API server port (default: 3001)
PORT=3001

# Optional: Web UI API base URL (default: http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001
